# ── Next.js / Supabase ───────────────────────────────────────────────────────

# Supabase — Settings → API
# ⚠ Ne jamais exposer SUPABASE_SERVICE_ROLE_KEY côté client !
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXX

# ── Cloudflare R2 ────────────────────────────────────────────────────────────

# Cloudflare Dashboard → R2 → Overview (Account ID en haut à droite)
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Dashboard → R2 → Manage API Tokens → Create API token
# Permission : Object Read & Write (bucket spécifique)
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Nom de ton bucket R2 (ex: affili-compare-images)
R2_BUCKET_NAME=affili-compare-images

# URL publique du bucket (Settings → Public Access → Enable, ou domaine custom)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ── Amazon Associates ────────────────────────────────────────────────────────

# Amazon Associates FR — Programme → Paramètres → ID de suivi
# Obtenu sur https://affiliate-program.amazon.fr
AMAZON_ASSOCIATE_TAG=mygoodpick-21

# PA-API (débloqué après 3 ventes confirmées) — https://affiliate-program.amazon.fr/assoc_credentials/home
# Laisser vide jusqu'à activation
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_PAAPI_PARTNER_TAG=mygoodpick-21

# ── Awin ────────────────────────────────────────────────────────────────────

# Awin Publisher Dashboard → API Access → Générer jeton
# https://wiki.awin.com/index.php/Awin_Technical_Documentation/API_Access_Token
AWIN_API_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AWIN_PUBLISHER_ID=1234567

# ── Pinterest API v5 ─────────────────────────────────────────────────────────

# OAuth flow → scripts/pinterest_oauth.py (ou refresh via refresh_pinterest_token.py)
# https://developers.pinterest.com/apps/ → ton app → Credentials
PINTEREST_ACCESS_TOKEN=pina_XXXXXXXX
PINTEREST_REFRESH_TOKEN=pinr_XXXXXXXX
PINTEREST_CLIENT_ID=1234567890123456789
PINTEREST_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID du board Pinterest de destination
# Récupérable via : GET https://api.pinterest.com/v5/boards
PINTEREST_BOARD_ID=1234567890123456789

# ── Hugging Face ──────────────────────────────────────────────────────────────

# https://huggingface.co/settings/tokens → New token (Read)
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Site ──────────────────────────────────────────────────────────────────────

# URL publique du site (sans trailing slash)
SITE_URL=https://mygoodpick.com

# Secret pour l'API ISR revalidation (invente une chaîne aléatoire longue)
# Utiliser : openssl rand -hex 32
REVALIDATE_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Ollama Cloud LLM ─────────────────────────────────────────────────────────

# https://cloud.ollama.com → Settings → API Keys
OLLAMA_CLOUD_API_KEY=ollama_cloud_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OLLAMA_CLOUD_HOST=https://cloud.ollama.com
OLLAMA_CLOUD_MODEL=minimax-m2.5:cloud

# ── Google Analytics (optionnel) ─────────────────────────────────────────────

# https://analytics.google.com → Admin → Stream → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
